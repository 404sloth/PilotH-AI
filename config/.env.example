# PilotH environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | groq | ollama
# If unset, auto-detects based on available API keys (openai > groq > ollama)
LLM_PRIMARY=ollama

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Groq (fast LLaMA inference) ───────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Ollama (local, always available as fallback) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Database ─────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=pilot_db.sqlite

# ── Human-in-the-Loop ────────────────────────────────────────────────────────
HITL_THRESHOLD=0.7

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=piloth-vendor
LANGSMITH_TRACING_V2=false

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
